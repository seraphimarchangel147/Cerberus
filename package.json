{
  "name": "openagi",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "description": "Generic ABI runtime scaffold for directional adaptive scrutiny, tiered memory, and propagation.",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spshulem/openAGI.git"
  },
  "homepage": "https://github.com/Spshulem/openAGI",
  "scripts": {
    "demo": "node examples/abi-demo.js",
    "serve": "node examples/hosted-server.js",
    "tunnel": "./scripts/tunnel.sh",
    "install-launchd": "./scripts/install-launchd.sh",
    "install-systemd": "./scripts/install-systemd.sh",
    "install-update-timer": "./scripts/install-update-timer.sh",
    "install-tunnel-launchd": "./scripts/install-tunnel-launchd.sh",
    "update": "./scripts/update.sh",
    "build-mac-app": "./scripts/build-mac-app.sh",
    "docker:build": "docker build -t openagi:local .",
    "docker:run": "docker run --rm -p 43210:43210 -v openagi-data:/data openagi:local",
    "test": "OPENAGI_AUTO_APPROVE=0 node --test",
    "test:prod-policy": "OPENAGI_AUTO_APPROVE=1 node --test",
    "test:all": "npm test && npm run test:prod-policy",
    "cli": "node bin/openagi.js"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "openagi": "bin/openagi.js"
  }
}
