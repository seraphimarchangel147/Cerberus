# OpenAGI environment configuration.
# Copy to .env or .openagi/.env and fill in. The daemon loads both.

# --- Model provider ---
# Per project rule: default to GPT-5 family.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
# Optional override:
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Twilio (SMS) ---
# Inbound: configure your Twilio phone number to POST messages to
#   https://<your-public-host>/channels/twilio/webhook
# Outbound (proactive sends, scheduled prompts that ping by SMS) needs:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Where the agent should text you proactively (your phone):
DEFAULT_SMS_TARGET=

# --- Telegram ---
# Create a bot via BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=
# Set to "1" to long-poll Telegram on startup. Leave blank if you'll register
# a webhook to /channels/telegram/webhook instead.
TELEGRAM_POLLING=

# --- Rize.io (time tracking) ---
# Generate an API key in Rize Settings → API Keys.
# Tools surfaced to the agent: rize_query (raw GraphQL), rize_today_summary, rize_recent_sessions.
RIZE_API_KEY=

# --- Budget cap ---
# Hard daily ceiling (USD). Provider calls throw BUDGET_EXCEEDED past this.
OPENAGI_DAILY_USD_LIMIT=10

# --- Auth (recommended once tunneled) ---
# Set to a strong random string; generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# When unset, the dashboard runs unauthenticated (local-only is OK; tunneled is not).
OPENAGI_AUTH_TOKEN=

# Public-facing URL for webhook signature verification (e.g. https://openagi.example.com).
# Required for Twilio signature checks when behind a tunnel; otherwise leave blank.
OPENAGI_PUBLIC_URL=

# Telegram webhook: shared secret. Set the same value when calling setWebhook.
TELEGRAM_WEBHOOK_SECRET=

# --- Daemon ---
HOST=127.0.0.1
PORT=43210
OPENAGI_DATA_DIR=.openagi
# Background ticker (ms). Set to 0 to disable; the runtime.tick() will then
# only run on POST /tick.
OPENAGI_TICKER_MS=10000
