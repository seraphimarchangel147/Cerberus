{
  "_comment": "Copy or rename to mcp.json. The runtime auto-loads .openagi/mcp.json on startup. Four shapes are supported:",
  "servers": {

    "//1": "── stdio: spawn a local process and talk JSON-RPC over stdin/stdout ──",
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "trustLevel": "trusted"
    },

    "//2": "── http + bearer: hit a remote URL with a static API key ──",
    "my-bearer-server": {
      "url": "https://my.mcp.server/mcp",
      "auth": "bearer",
      "apiKey": "${MY_MCP_KEY}",
      "trustLevel": "trusted"
    },

    "//3": "── http + oauth (dynamic registration): for OIDC servers like Keycloak/Auth0 ──",
    "my-dcr-server": {
      "url": "https://mcp.example.com/mcp",
      "auth": "oauth",
      "trustLevel": "trusted"
    },

    "//4": "── http + oauth with pre-registered client (for servers without DCR) ──",
    "my-oauth-server": {
      "url": "https://api.example.com/mcp",
      "auth": "oauth",
      "clientId": "${MY_OAUTH_CLIENT_ID}",
      "clientSecret": "${MY_OAUTH_CLIENT_SECRET}",
      "scope": "mcp.read mcp.write",
      "trustLevel": "trusted"
    }
  }
}
